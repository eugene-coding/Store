@if (badges is not null)
{
        <ul class="badges no-default">
            @foreach (var badge in badges)
            {
                <li>
                    <a href="@badge.Url" target="_blank" title="@badge.Title" >
                        <img class="badges__image" src="@(BadgeImagesPath + badge.Image)" width="@badge.Width" height="@badge.Height" alt="@badge.Title" />
                    </a>
                </li>
            }
        </ul>
}
else
{
    <Loading />
}
