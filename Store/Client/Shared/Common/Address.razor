<address class="@_class">
    <div class="address__item item">
        <i class="item__icon fa-solid fa-phone"></i>
        <a class="item__text item__text_phone" href="tel:@StoreSettings["Phone"]">@StoreSettings["Phone"]</a>
    </div>

    <div class="address__item item">
        <i class="item__icon fa-regular fa-envelope"></i>
        <a class="item__text" href="mailto:@StoreSettings["Email"]">@StoreSettings["Email"]</a>
    </div> 

    <div class="address__item item">
        <i class="item__icon fa-solid fa-location-dot"></i>
        <span class="item__text">@_fullAddress</span>
    </div>
</address>
