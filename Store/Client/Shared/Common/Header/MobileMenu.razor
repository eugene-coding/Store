<div id="mobile-menu">
    <div class="header">
        <a href="/">
            <img src="@StoreSettings["Logo"]" height="37" width="141" alt="@StoreSettings["Name"]" loading="lazy" />
        </a>

        <button class="close no-style" @onclick=Close>
            <i class="close__icon fa-solid fa-plus"></i>
        </button>
    </div>

    <nav class="body">
        <ul class="menu no-style">
            <li class="menu__item">
                <a class="menu__link" href="/">Проекты</a>
            </li>
            <li class="menu__item">
                <a class="menu__link" href="/">Каталог</a>
            </li>
            <li class="menu__item menu__item_active">Услуги</li>
            <li class="menu__item">
                <a class="menu__link" href="@Contacts.Url">@ContactsText["HeadingTitle"]</a>
            </li>
        </ul>
    </nav>
</div>

<div id="mobile-menu-overlay" class="overlay" @onclick=Close></div>
