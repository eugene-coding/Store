@if (s_socials is not null && s_socials.Count > 0)
{
    <ul class="social no-style">
        @foreach (var social in s_socials)
        {
            <li>
                <a class="@social.Key" href="@social.Value" rel="nofollow noopener" target="_blank">
                    <i class="fa-brands fa-@social.Key"></i>
                </a>
            </li>
        }
    </ul>
}
